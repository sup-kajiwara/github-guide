{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u306f\u3058\u3081\u306b","text":"GitHub\u306e\u4e16\u754c\u3078\u3001\u3088\u3046\u3053\u305d \ud83d\udc4b <p>\u3053\u306e\u30b5\u30a4\u30c8\u306f\u3001GitHub\uff08\u30ae\u30c3\u30c8\u30cf\u30d6\uff09\u3092\u306f\u3058\u3081\u3066\u4f7f\u3046\u65b9\u306e\u305f\u3081\u306e\u5165\u9580\u30ac\u30a4\u30c9\u3067\u3059\u3002 \u5c02\u9580\u7528\u8a9e\u306f\u3067\u304d\u308b\u3060\u3051\u304b\u307f\u304f\u3060\u3044\u3066\u8aac\u660e\u3057\u307e\u3059\u3002\u9806\u756a\u306b\u8aad\u307f\u9032\u3081\u308c\u3070\u3001\u3072\u3068\u308a\u3067\u3082\u57fa\u672c\u64cd\u4f5c\u304c\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002</p> <p>\u8aad\u307f\u65b9\u306e\u304a\u3059\u3059\u3081</p> <p>\u307e\u305a\u306f\u6b21\u306e\u300c\u7528\u8a9e\u96c6\u300d\u3067\u8a00\u8449\u306e\u30a4\u30e1\u30fc\u30b8\u3092\u3064\u304b\u3093\u3067\u304b\u3089\u3001\u4e0a\u304b\u3089\u9806\u306b\u8aad\u3080\u306e\u304c\u304a\u3059\u3059\u3081\u3067\u3059\u3002 \u3059\u3079\u3066\u3092\u6697\u8a18\u3059\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u56f0\u3063\u305f\u3089\u691c\u7d22\uff08\u753b\u9762\u53f3\u4e0a\u306e\ud83d\udd0d\uff09\u3067\u63a2\u305b\u307e\u3059\u3002</p>"},{"location":"#github","title":"GitHub\uff08\u30ae\u30c3\u30c8\u30cf\u30d6\uff09\u3063\u3066\u4f55\uff1f","text":"\u30d5\u30a1\u30a4\u30eb\u3092\u30cd\u30c3\u30c8\u4e0a\u306b\u7f6e\u3044\u3066\u3001\u307f\u3093\u306a\u3067\u5171\u6709\u30fb\u7ba1\u7406\u3067\u304d\u308b <p>\u3072\u3068\u3053\u3068\u3067\u8a00\u3046\u3068\u3001\u30d5\u30a1\u30a4\u30eb\u306e\u4fdd\u7ba1\u30fb\u5171\u6709\u30fb\u5909\u66f4\u5c65\u6b74\u306e\u7ba1\u7406\u304c\u3067\u304d\u308bWeb\u30b5\u30fc\u30d3\u30b9\u3067\u3059\u3002</p> <p>\u8eab\u8fd1\u306a\u3082\u306e\u3067\u305f\u3068\u3048\u308b\u3068\uff1a</p> <ul> <li>Google\u30c9\u30e9\u30a4\u30d6\u306e\u3088\u3046\u306b\u3001\u30d5\u30a1\u30a4\u30eb\u3092\u30cd\u30c3\u30c8\u4e0a\u306b\u7f6e\u3044\u3066\u307f\u3093\u306a\u3067\u5171\u6709\u3067\u304d\u308b</li> <li>\u305d\u306e\u3046\u3048\u3067\u3001\u300c\u3044\u3064\u30fb\u8ab0\u304c\u30fb\u3069\u3053\u3092\u5909\u3048\u305f\u304b\u300d\u304c\u3059\u3079\u3066\u8a18\u9332\u3055\u308c\u308b</li> <li>\u3055\u3089\u306b\u3001\u524d\u306e\u72b6\u614b\u306b\u3044\u3064\u3067\u3082\u623b\u305b\u308b</li> </ul> <p>\u3053\u306e\u300c\u5909\u66f4\u306e\u5c65\u6b74\u3092\u6b8b\u3059\u4ed5\u7d44\u307f\u300d\u306e\u3053\u3068\u3092 Git\uff08\u30ae\u30c3\u30c8\uff09 \u3068\u547c\u3073\u3001\u305d\u308c\u3092Web\u3067\u307f\u3093\u306a\u304c\u4f7f\u3048\u308b\u3088\u3046\u306b\u3057\u305f\u30b5\u30fc\u30d3\u30b9\u304c GitHub \u3067\u3059\u3002</p> <pre><code>flowchart LR\n    G[(\"\u30d5\u30a1\u30a4\u30eb&lt;br/&gt;\ud83d\udcc4\ud83d\udcc4\ud83d\udcc4\")] --&gt; H{{GitHub}}\n    H --&gt; S1[\"\u5171\u6709&lt;br/&gt;\ud83d\udc65\"]\n    H --&gt; S2[\"\u5c65\u6b74\u3092\u8a18\u9332&lt;br/&gt;\ud83d\udd52\"]\n    H --&gt; S3[\"\u524d\u306b\u623b\u305b\u308b&lt;br/&gt;\u21a9\ufe0f\"]</code></pre>"},{"location":"#_2","title":"\u306a\u305c\u4f7f\u3046\u306e\uff1f\uff08\u30e1\u30ea\u30c3\u30c8\uff09","text":"\u300c\u3044\u3064\u30fb\u8ab0\u304c\u30fb\u306a\u305c\u5909\u3048\u305f\u304b\u300d\u304c\u305c\u3093\u3076\u6b8b\u308b <ul> <li>\u4e0a\u66f8\u304d\u4e8b\u6545\u304c\u9632\u3052\u308b \u2026 \u300c\u6700\u65b0\u7248\u3069\u308c\u3060\u3063\u3051\uff1f\u300d\u300c\u4e0a\u66f8\u304d\u3057\u3066\u6d88\u3048\u305f\u2026\u300d\u304c\u306a\u304f\u306a\u308b</li> <li>\u8ab0\u304c\u4f55\u3092\u5909\u3048\u305f\u304b\u5206\u304b\u308b \u2026 \u5909\u66f4\u306e\u7406\u7531\u3082\u30b3\u30e1\u30f3\u30c8\u3067\u6b8b\u305b\u308b</li> <li>\u5171\u540c\u4f5c\u696d\u304c\u3057\u3084\u3059\u3044 \u2026 \u8907\u6570\u4eba\u3067\u540c\u3058\u30d5\u30a1\u30a4\u30eb\u3092\u5b89\u5168\u306b\u7de8\u96c6\u3067\u304d\u308b</li> <li>\u3044\u3064\u3067\u3082\u904e\u53bb\u306b\u623b\u305b\u308b \u2026 \u9593\u9055\u3048\u3066\u3082\u524d\u306e\u72b6\u614b\u306b\u5fa9\u5143\u3067\u304d\u308b</li> </ul> \u8907\u6570\u4eba\u3067\u3082\u3001\u3076\u3064\u304b\u3089\u305a\u306b\u5b89\u5168\u306b\u4f5c\u696d\u3067\u304d\u308b <p>\u30a8\u30f3\u30b8\u30cb\u30a2\u3060\u3051\u306e\u3082\u306e\uff1f</p> <p>\u3044\u3044\u3048\u3002\u30d7\u30ed\u30b0\u30e9\u30e0\u306e\u30b3\u30fc\u30c9\u306f\u3082\u3061\u308d\u3093\u3001\u6587\u7ae0\u30fb\u8cc7\u6599\u30fb\u624b\u9806\u66f8\u30fb\u30c7\u30fc\u30bf\u306e\u7ba1\u7406\u306b\u3082\u4f7f\u308f\u308c\u3066\u3044\u307e\u3059\u3002 \u5b9f\u969b\u3001\u3053\u306e\u8cc7\u6599\u81ea\u4f53\u3082GitHub\u3067\u7ba1\u7406\u3057\u3066\u516c\u958b\u3057\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"#_3","title":"\u3053\u306e\u30ac\u30a4\u30c9\u306e\u30b4\u30fc\u30eb","text":"\u9806\u756a\u306b\u30af\u30ea\u30a2\u3057\u3066\u3044\u3051\u3070\u5927\u4e08\u592b \u2705 <p>\u8aad\u307f\u7d42\u3048\u308b\u3068\u3001\u6b21\u306e\u3053\u3068\u304c\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002</p> <ol> <li>\u81ea\u5206\u306eGitHub\u30a2\u30ab\u30a6\u30f3\u30c8\u3092\u4f5c\u308c\u308b</li> <li>\u30d5\u30a1\u30a4\u30eb\u3092\u7f6e\u304f\u5834\u6240\uff08\u30ea\u30dd\u30b8\u30c8\u30ea\uff09\u3092\u4f5c\u308c\u308b</li> <li>\u5909\u66f4\u3092\u8a18\u9332\u3057\u3066\u4fdd\u5b58\u3067\u304d\u308b\uff08\u30b3\u30df\u30c3\u30c8\u30fb\u30d7\u30c3\u30b7\u30e5\uff09</li> <li>\u307b\u304b\u306e\u4eba\u3068\u4e00\u7dd2\u306b\u4f5c\u696d\u3059\u308b\u6d41\u308c\u304c\u5206\u304b\u308b\uff08\u30d7\u30eb\u30ea\u30af\u30a8\u30b9\u30c8\u30fb\u30de\u30fc\u30b8\uff09</li> <li>\u56f0\u3063\u305f\u3068\u304d\u306e\u8abf\u3079\u65b9\u304c\u5206\u304b\u308b</li> </ol> <p>\u305d\u308c\u3067\u306f\u3001\u307e\u305a\u7528\u8a9e\u96c6\u304b\u3089\u898b\u3066\u3044\u304d\u307e\u3057\u3087\u3046\u3002</p> <p>\u30a4\u30e9\u30b9\u30c8\u306b\u3064\u3044\u3066</p> <p>\u672c\u30b5\u30a4\u30c8\u306e\u30a4\u30e9\u30b9\u30c8\u306f unDraw\uff08\u5e30\u5c5e\u4e0d\u8981\u30fb\u5546\u7528\u5229\u7528\u53ef\u306e\u30aa\u30fc\u30d7\u30f3\u30e9\u30a4\u30bb\u30f3\u30b9\uff09\u3092\u4f7f\u7528\u3057\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"account-setup/","title":"\u30a2\u30ab\u30a6\u30f3\u30c8\u4f5c\u6210\u3068\u521d\u671f\u8a2d\u5b9a","text":"<p>\u3053\u306e\u7ae0\u306e\u30b4\u30fc\u30eb</p> <p>\u81ea\u5206\u306eGitHub\u30a2\u30ab\u30a6\u30f3\u30c8\u3092\u4f5c\u308a\u3001\u30ed\u30b0\u30a4\u30f3\u3067\u304d\u308b\u72b6\u614b\u306b\u306a\u308b\u3053\u3068\u3002 \u3042\u308f\u305b\u3066\u3001\u5b89\u5168\u306b\u4f7f\u3046\u305f\u3081\u306e\u521d\u671f\u8a2d\u5b9a\uff082\u6bb5\u968e\u8a8d\u8a3c\u306a\u3069\uff09\u307e\u3067\u6e08\u307e\u305b\u307e\u3059\u3002</p>"},{"location":"account-setup/#_2","title":"\u5168\u4f53\u306e\u6d41\u308c","text":"<p>\u3053\u308c\u304b\u3089\u3084\u308b\u3053\u3068\u3092\u3001\u5148\u306b\u5730\u56f3\u3067\u898b\u3066\u304a\u304d\u307e\u3057\u3087\u3046\u3002\u6240\u8981\u6642\u9593\u306f\u3060\u3044\u305f\u3044 10\u301c15\u5206 \u3067\u3059\u3002</p> <pre><code>flowchart LR\n    A([\u30b9\u30bf\u30fc\u30c8]) --&gt; B[1. \u30a2\u30ab\u30a6\u30f3\u30c8\u3092\u4f5c\u308b]\n    B --&gt; C[2. \u30e1\u30fc\u30eb\u8a8d\u8a3c\u3092\u3059\u308b]\n    C --&gt; D[3. \u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u306e\u521d\u671f\u8a2d\u5b9a]\n    D --&gt; E[4. \u5b89\u5168\u306e\u305f\u3081\u306e\u8a2d\u5b9a&lt;br/&gt;2\u6bb5\u968e\u8a8d\u8a3c]\n    E --&gt; F([\u30ed\u30b0\u30a4\u30f3\u3067\u304d\u308b\u72b6\u614b \ud83c\udf89])</code></pre> <p>\u306f\u3058\u3081\u306b\uff1a\u4f1a\u793e\u306e\u30eb\u30fc\u30eb\u3092\u78ba\u8a8d</p> <p>\u4f1a\u793e\u3067\u4f7f\u3046\u5834\u5408\u306f\u3001\u4f1a\u793e\u306e\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3067\u767b\u9332\u3059\u308b\u304b\u3001\u793e\u5185\u30eb\u30fc\u30eb\u306b\u5f93\u3063\u3066\u304f\u3060\u3055\u3044\u3002 \u3059\u3067\u306b\u300c\u3053\u306e\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3067\u4f5c\u3063\u3066\u300d\u3068\u6848\u5185\u3055\u308c\u3066\u3044\u308b\u5834\u5408\u306f\u3001\u305d\u308c\u306b\u5f93\u3044\u307e\u3057\u3087\u3046\u3002</p>"},{"location":"account-setup/#1","title":"1. \u30a2\u30ab\u30a6\u30f3\u30c8\u3092\u4f5c\u308b","text":"<p>\u30d6\u30e9\u30a6\u30b6\uff08Chrome \u3084 Edge\uff09\u3067 https://github.com \u3092\u958b\u304d\u307e\u3059\u3002</p> <pre><code>flowchart TD\n    A[github.com \u3092\u958b\u304f] --&gt; B[\"\u53f3\u4e0a\u306e Sign up \u3092\u62bc\u3059\"]\n    B --&gt; C[\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3092\u5165\u529b]\n    C --&gt; D[\u30d1\u30b9\u30ef\u30fc\u30c9\u3092\u5165\u529b]\n    D --&gt; E[\u30e6\u30fc\u30b6\u30fc\u540d\u3092\u5165\u529b]\n    E --&gt; F[\"\u6848\u5185\u306b\u5f93\u3063\u3066\u30af\u30a4\u30ba\uff0f\u78ba\u8a8d\u306b\u7b54\u3048\u308b\"]\n    F --&gt; G[Create account \u3092\u62bc\u3059]</code></pre> <p>\u64cd\u4f5c\u306e\u5bfe\u5fdc\u8868\u3067\u3059\u3002\u82f1\u8a9e\u306e\u30dc\u30bf\u30f3\u304c\u591a\u3044\u306e\u3067\u3001\u8ff7\u3063\u305f\u3089\u3053\u3053\u3092\u898b\u3066\u304f\u3060\u3055\u3044\u3002</p> \u753b\u9762\u306e\u8868\u793a\uff08\u82f1\u8a9e\uff09 \u610f\u5473\u30fb\u3084\u308b\u3053\u3068 Sign up \u65b0\u898f\u767b\u9332\uff08\u30a2\u30ab\u30a6\u30f3\u30c8\u3092\u4f5c\u308b\uff09 Enter your email \u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3092\u5165\u529b Create a password \u30d1\u30b9\u30ef\u30fc\u30c9\u3092\u4f5c\u308b Enter a username \u30e6\u30fc\u30b6\u30fc\u540d\uff08\u534a\u89d2\u82f1\u6570\u5b57\uff09\u3092\u6c7a\u3081\u308b Continue / Create account \u6b21\u3078\u9032\u3080\uff0f\u767b\u9332\u3092\u78ba\u5b9a\u3059\u308b <p>\ud83d\udcf7 \u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\u67a0\uff08\u3042\u3068\u3067\u5dee\u3057\u8fbc\u307f\uff09</p> <p>\u3053\u3053\u306b Sign up \u30dc\u30bf\u30f3\u306e\u5834\u6240 \u304c\u308f\u304b\u308b\u753b\u9762\u3092\u5165\u308c\u307e\u3059\u3002 \u753b\u50cf\u304c\u7528\u610f\u3067\u304d\u305f\u3089\u3001\u3053\u306e\u67a0\u3092\u6b21\u306e1\u884c\u306b\u7f6e\u304d\u63db\u3048\u3066\u304f\u3060\u3055\u3044\uff1a <code>![Sign up\u30dc\u30bf\u30f3\u306e\u5834\u6240](images/account-01-signup.png){ width=\"700\" }</code></p> <p>\u500b\u4eba\u60c5\u5831\u306e\u53d6\u308a\u6271\u3044\u306b\u6ce8\u610f</p> <ul> <li>\u767b\u9332\u306b\u4f7f\u3046\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3084\u30d1\u30b9\u30ef\u30fc\u30c9\u306f\u3001\u3053\u306e\u8cc7\u6599\u3084\u793e\u5185\u30c1\u30e3\u30c3\u30c8\u306b\u8cbc\u308a\u4ed8\u3051\u306a\u3044\u3067\u304f\u3060\u3055\u3044\u3002</li> <li>\u30d1\u30b9\u30ef\u30fc\u30c9\u306f\u4ed6\u30b5\u30fc\u30d3\u30b9\u3068\u4f7f\u3044\u56de\u3055\u306a\u3044\u3067\u304f\u3060\u3055\u3044\u3002</li> </ul> \u30e6\u30fc\u30b6\u30fc\u540d\u306e\u6c7a\u3081\u65b9\uff08\u30af\u30ea\u30c3\u30af\u3067\u958b\u304f\uff09 <ul> <li>\u534a\u89d2\u306e\u82f1\u6570\u5b57\u3068\u30cf\u30a4\u30d5\u30f3\u304c\u4f7f\u3048\u307e\u3059\uff08\u4f8b\uff1a<code>taro-example</code>\uff09\u3002</li> <li>\u5f8c\u304b\u3089\u5909\u66f4\u3082\u3067\u304d\u307e\u3059\u304c\u3001URL\u304c\u5909\u308f\u308b\u305f\u3081\u6700\u521d\u306b\u6c7a\u3081\u3066\u304a\u304f\u306e\u304c\u304a\u3059\u3059\u3081\u3067\u3059\u3002</li> <li>\u5b9f\u540d\u3067\u306a\u304f\u3066\u3082\u304b\u307e\u3044\u307e\u305b\u3093\u304c\u3001\u793e\u5185\u3067\u4f7f\u3046\u306a\u3089\u8ab0\u304b\u5206\u304b\u308b\u540d\u524d\u306b\u3057\u3066\u304a\u304f\u3068\u4fbf\u5229\u3067\u3059\u3002</li> </ul>"},{"location":"account-setup/#2","title":"2. \u30e1\u30fc\u30eb\u8a8d\u8a3c\u3092\u3059\u308b","text":"<p>\u767b\u9332\u3057\u305f\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u306b\u3001GitHub\u304b\u3089\u78ba\u8a8d\u30b3\u30fc\u30c9\uff08\u6570\u5b57\uff09\u304c\u5c4a\u304d\u307e\u3059\u3002</p> <pre><code>flowchart LR\n    A[\u30e1\u30fc\u30eb\u3092\u958b\u304f] --&gt; B[\u78ba\u8a8d\u30b3\u30fc\u30c9\u3092\u78ba\u8a8d&lt;br/&gt;\u4f8b\uff1a8\u6841\u306e\u6570\u5b57]\n    B --&gt; C[GitHub\u306e\u753b\u9762\u306b\u5165\u529b]\n    C --&gt; D([\u8a8d\u8a3c\u5b8c\u4e86 \u2705])</code></pre> <p>\u30b3\u30fc\u30c9\u304c\u5c4a\u304b\u306a\u3044\u3068\u304d\u306f</p> <ul> <li>\u8ff7\u60d1\u30e1\u30fc\u30eb\u30d5\u30a9\u30eb\u30c0\u3092\u78ba\u8a8d\u3057\u3066\u304f\u3060\u3055\u3044\u3002</li> <li>\u6570\u5206\u5f85\u3063\u3066\u3082\u5c4a\u304b\u306a\u3051\u308c\u3070\u3001\u753b\u9762\u306e Resend\uff08\u518d\u9001\uff09 \u3092\u62bc\u3057\u307e\u3059\u3002</li> <li>\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u306e\u6253\u3061\u9593\u9055\u3044\u304c\u306a\u3044\u304b\u3001\u3082\u3046\u4e00\u5ea6\u78ba\u8a8d\u3057\u307e\u3057\u3087\u3046\u3002</li> </ul> <p>\ud83d\udcf7 \u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\u67a0\uff08\u3042\u3068\u3067\u5dee\u3057\u8fbc\u307f\uff09</p> <p>\u78ba\u8a8d\u30b3\u30fc\u30c9\u306e\u5165\u529b\u753b\u9762\u3092\u5165\u308c\u308b\u5834\u6240\u3067\u3059\u3002 <code>![\u78ba\u8a8d\u30b3\u30fc\u30c9\u306e\u5165\u529b\u753b\u9762](images/account-02-verify.png){ width=\"700\" }</code></p>"},{"location":"account-setup/#3","title":"3. \u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u306e\u521d\u671f\u8a2d\u5b9a","text":"<p>\u30ed\u30b0\u30a4\u30f3\u3067\u304d\u305f\u3089\u3001\u6700\u4f4e\u9650\u306e\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u3092\u6574\u3048\u307e\u3059\u3002\u3042\u3068\u304b\u3089\u3067\u3082\u5909\u66f4\u3067\u304d\u308b\u306e\u3067\u3001\u307e\u305a\u306f\u8efd\u304f\u3067OK\u3067\u3059\u3002</p> <ul> <li>\u8868\u793a\u540d\uff08Name\uff09\uff1a\u793e\u5185\u3067\u8ab0\u304b\u5206\u304b\u308b\u540d\u524d\u306b\u3057\u3066\u304a\u304f\u3068\u3001\u5171\u540c\u4f5c\u696d\u306e\u3068\u304d\u306b\u4fbf\u5229\u3067\u3059\u3002</li> <li>\u30a2\u30a4\u30b3\u30f3\uff08Profile picture\uff09\uff1a\u9854\u5199\u771f\u3067\u306a\u304f\u3066\u3082OK\u3002\u8a2d\u5b9a\u3059\u308b\u3068\u898b\u5206\u3051\u304c\u3064\u304d\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002</li> </ul> <p>\u8a2d\u5b9a\u5834\u6240\u3078\u306e\u884c\u304d\u65b9\uff1a</p> <pre><code>flowchart LR\n    A[\u53f3\u4e0a\u306e\u30a2\u30a4\u30b3\u30f3\u3092\u62bc\u3059] --&gt; B[\"Settings\uff08\u8a2d\u5b9a\uff09\u3092\u62bc\u3059\"]\n    B --&gt; C[\"Public profile \u3067&lt;br/&gt;\u540d\u524d\u30fb\u30a2\u30a4\u30b3\u30f3\u3092\u7de8\u96c6\"]\n    C --&gt; D[\"Update profile \u3067\u4fdd\u5b58\"]</code></pre> <p>\ud83d\udcf7 \u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\u67a0\uff08\u3042\u3068\u3067\u5dee\u3057\u8fbc\u307f\uff09</p> <p>Settings\uff08\u8a2d\u5b9a\uff09\u306e\u5834\u6240\u304c\u308f\u304b\u308b\u753b\u9762\u3092\u5165\u308c\u307e\u3059\u3002 <code>![\u8a2d\u5b9a\u30e1\u30cb\u30e5\u30fc\u306e\u5834\u6240](images/account-03-settings.png){ width=\"700\" }</code></p>"},{"location":"account-setup/#4-2","title":"4. \u5b89\u5168\u306e\u305f\u3081\u306e\u8a2d\u5b9a\uff082\u6bb5\u968e\u8a8d\u8a3c\uff09","text":"<p>\u3053\u3053\u306f\u5fc5\u305a\u8a2d\u5b9a\u3057\u307e\u3057\u3087\u3046</p> <p>GitHub\u306f\u5927\u5207\u306a\u30d5\u30a1\u30a4\u30eb\u3092\u7f6e\u304f\u5834\u6240\u3067\u3059\u30022\u6bb5\u968e\u8a8d\u8a3c\uff082FA\uff09 \u3092\u8a2d\u5b9a\u3059\u308b\u3068\u3001 \u4e07\u4e00\u30d1\u30b9\u30ef\u30fc\u30c9\u304c\u6f0f\u308c\u3066\u3082\u3001\u672c\u4eba\u4ee5\u5916\u306f\u30ed\u30b0\u30a4\u30f3\u3067\u304d\u306a\u304f\u306a\u308a\u307e\u3059\u3002</p> <p>2\u6bb5\u968e\u8a8d\u8a3c\u306f\u3001\u30ed\u30b0\u30a4\u30f3\u6642\u306b\u300c\u30d1\u30b9\u30ef\u30fc\u30c9\u300d\uff0b\u300c\u30b9\u30de\u30db\u30a2\u30d7\u30ea\u306e\u6570\u5b57\u300d\u306e2\u3064\u3092\u4f7f\u3046\u4ed5\u7d44\u307f\u3067\u3059\u3002</p> <pre><code>flowchart LR\n    P[\u30d1\u30b9\u30ef\u30fc\u30c9] --&gt; L{\u30ed\u30b0\u30a4\u30f3}\n    S[\u30b9\u30de\u30db\u306e\u8a8d\u8a3c\u30a2\u30d7\u30ea&lt;br/&gt;\u306e6\u6841\u30b3\u30fc\u30c9] --&gt; L\n    L --&gt; OK([\u672c\u4eba\u3060\u3051\u5165\u308c\u308b \ud83d\udd12])</code></pre> <p>\u8a2d\u5b9a\u306e\u5165\u308a\u53e3\uff1aSettings \u2192 Password and authentication \u2192 Two-factor authentication \u304b\u3089\u9032\u3081\u307e\u3059\u3002 \u753b\u9762\u306e\u6848\u5185\u306b\u5f93\u3063\u3066\u3001\u30b9\u30de\u30db\u306e\u8a8d\u8a3c\u30a2\u30d7\u30ea\uff08\u4f8b\uff1aGoogle Authenticator \u306a\u3069\uff09\u3068\u9023\u643a\u3057\u307e\u3059\u3002</p> <p>\u30ea\u30ab\u30d0\u30ea\u30fc\u30b3\u30fc\u30c9\u306f\u5fc5\u305a\u4fdd\u7ba1</p> <p>2\u6bb5\u968e\u8a8d\u8a3c\u3092\u8a2d\u5b9a\u3059\u308b\u3068\u3001\u30ea\u30ab\u30d0\u30ea\u30fc\u30b3\u30fc\u30c9\uff08\u7dca\u6025\u7528\u306e\u5408\u8a00\u8449\uff09\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002 \u30b9\u30de\u30db\u3092\u5931\u304f\u3057\u305f\u3068\u304d\u306e\u547d\u7db1\u306a\u306e\u3067\u3001\u5b89\u5168\u306a\u5834\u6240\u306b\u4fdd\u7ba1\u3057\u3066\u304f\u3060\u3055\u3044\u3002\u793e\u5185\u30c1\u30e3\u30c3\u30c8\u7b49\u306b\u306f\u8cbc\u3089\u306a\u3044\u3053\u3068\u3002</p>"},{"location":"account-setup/#_3","title":"\u3053\u306e\u7ae0\u306e\u307e\u3068\u3081","text":"<pre><code>flowchart LR\n    A[\u30a2\u30ab\u30a6\u30f3\u30c8\u4f5c\u6210] --&gt; B[\u30e1\u30fc\u30eb\u8a8d\u8a3c]\n    B --&gt; C[\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u8a2d\u5b9a]\n    C --&gt; D[2\u6bb5\u968e\u8a8d\u8a3c]\n    D --&gt; E([\u6e96\u5099\u5b8c\u4e86 \ud83c\udf89])</code></pre> <ul> <li>[x] GitHub\u306b\u30ed\u30b0\u30a4\u30f3\u3067\u304d\u308b</li> <li>[x] \u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u3092\u8a2d\u5b9a\u3057\u305f</li> <li>[x] 2\u6bb5\u968e\u8a8d\u8a3c\u3067\u5b89\u5168\u306b\u3057\u305f</li> </ul> <p>\u6b21\u306e\u30b9\u30c6\u30c3\u30d7</p> <p>\u30a2\u30ab\u30a6\u30f3\u30c8\u306e\u6e96\u5099\u304c\u3067\u304d\u307e\u3057\u305f\u3002 \u3053\u306e\u30ac\u30a4\u30c9\u3067\u306f\u3001\u3053\u308c\u4ee5\u964d\u306e\u64cd\u4f5c\u3092 VSCode + Claude \u3092\u4f7f\u3063\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002 \u6b21\u306e\u7ae0\u3067\u3001\u81ea\u5206\u306e\u30d5\u30a1\u30a4\u30eb\u7f6e\u304d\u5834\uff08\u30ea\u30dd\u30b8\u30c8\u30ea\uff09\u3092\u4f5c\u3063\u3066\u307f\u307e\u3057\u3087\u3046\u3002</p> <p>\ud83d\udc49 \u6700\u521d\u306e\u4e00\u6b69\uff08\u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u4f5c\u308b\uff09</p>"},{"location":"collaboration/","title":"\u307f\u3093\u306a\u3067\u4f7f\u3046\uff08\u30d7\u30eb\u30ea\u30af\u30fb\u30de\u30fc\u30b8\uff09","text":"<p>\u3053\u306e\u7ae0\u306e\u30b4\u30fc\u30eb</p> <p>\u8907\u6570\u4eba\u3067\u5b89\u5168\u306b\u5171\u540c\u4f5c\u696d\u3059\u308b\u6d41\u308c\uff08\u30d6\u30e9\u30f3\u30c1 \u2192 \u30d7\u30eb\u30ea\u30af\u30a8\u30b9\u30c8 \u2192 \u30de\u30fc\u30b8\uff09\u304c\u5206\u304b\u308b\u3053\u3068\u3002</p>"},{"location":"collaboration/#1","title":"1. \u30d6\u30e9\u30f3\u30c1\u3092\u4f5c\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1a\u672c\u4f53\u3092\u5b88\u308a\u306a\u304c\u3089\u4f5c\u696d\u3059\u308b\u8003\u3048\u65b9\uff09</p>"},{"location":"collaboration/#2","title":"2. \u5909\u66f4\u3057\u3066\u30d7\u30eb\u30ea\u30af\u30a8\u30b9\u30c8\u3092\u51fa\u3059","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1aPull Request \u306e\u4f5c\u308a\u65b9\u30fb\u30ec\u30d3\u30e5\u30fc\u4f9d\u983c\uff09</p>"},{"location":"collaboration/#3","title":"3. \u30ec\u30d3\u30e5\u30fc\u3057\u3066\u30de\u30fc\u30b8\u3059\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1a\u30b3\u30e1\u30f3\u30c8\u30fb\u627f\u8a8d\u30fb\u30de\u30fc\u30b8\u306e\u6d41\u308c\uff09</p> <p>\u304a\u3059\u3059\u3081\u306e\u9032\u3081\u65b9</p> <p>\u3044\u304d\u306a\u308a\u672c\u4f53\u3092\u5909\u3048\u305a\u3001\u300c\u30d6\u30e9\u30f3\u30c1\u3067\u4f5c\u696d \u2192 \u30d7\u30eb\u30ea\u30af\u3067\u76f8\u8ac7 \u2192 \u30de\u30fc\u30b8\u300d\u306e\u6d41\u308c\u3092\u7fd2\u6163\u306b\u3059\u308b\u3068\u5b89\u5168\u3067\u3059\u3002</p>"},{"location":"commit-push/","title":"\u5909\u66f4\u3092\u8a18\u9332\u3059\u308b\uff08\u30b3\u30df\u30c3\u30c8\uff09","text":"<p>\u3053\u306e\u7ae0\u306e\u30b4\u30fc\u30eb</p> <p>\u30d5\u30a1\u30a4\u30eb\u3092\u5909\u66f4\u3057\u3066\u3001\u305d\u306e\u5909\u66f4\u3092\u8a18\u9332\uff08\u30b3\u30df\u30c3\u30c8\uff09\u30fb\u4fdd\u5b58\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308b\u3053\u3068\u3002</p>"},{"location":"commit-push/#1","title":"1. \u30b3\u30df\u30c3\u30c8\u3068\u306f\uff08\u304a\u3055\u3089\u3044\uff09","text":"<p>\uff08\u3053\u3053\u306b\u8aac\u660e\u3092\u66f8\u304d\u307e\u3059\uff1a\u7528\u8a9e\u96c6\u306e\u30b3\u30df\u30c3\u30c8\u3092\u53c2\u7167\uff09</p>"},{"location":"commit-push/#2","title":"2. \u30d6\u30e9\u30a6\u30b6\u4e0a\u3067\u5909\u66f4\u3057\u3066\u30b3\u30df\u30c3\u30c8\u3059\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1a\u30d5\u30a1\u30a4\u30eb\u3092\u7de8\u96c6 \u2192 \u30b3\u30df\u30c3\u30c8\u30e1\u30c3\u30bb\u30fc\u30b8\u3092\u66f8\u304f \u2192 Commit changes\uff09</p>"},{"location":"commit-push/#3","title":"3. \u826f\u3044\u30b3\u30df\u30c3\u30c8\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u66f8\u304d\u65b9","text":"<p>\uff08\u3053\u3053\u306b\u8aac\u660e\u3092\u66f8\u304d\u307e\u3059\uff1a\u4f55\u3092\u5909\u3048\u305f\u304b\u4e00\u8a00\u3067\u30fb\u4f8b\u3064\u304d\uff09</p>"},{"location":"first-steps/","title":"\u6700\u521d\u306e\u4e00\u6b69\uff08\u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u4f5c\u308b\uff09","text":"<p>\u3053\u306e\u7ae0\u306e\u30b4\u30fc\u30eb</p> <p>\u81ea\u5206\u306e\u30d5\u30a1\u30a4\u30eb\u7f6e\u304d\u5834\uff08\u30ea\u30dd\u30b8\u30c8\u30ea\uff09\u3092\u4f5c\u308a\u3001\u30d5\u30a1\u30a4\u30eb\u3092\u7f6e\u3051\u308b\u3088\u3046\u306b\u306a\u308b\u3053\u3068\u3002</p>"},{"location":"first-steps/#1","title":"1. \u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u4f5c\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1aNew repository \u2192 \u540d\u524d\u30fb\u516c\u958b/\u975e\u516c\u958b\u306e\u9078\u629e \u2192 README\u8ffd\u52a0\uff09</p>"},{"location":"first-steps/#2","title":"2. \u30d5\u30a1\u30a4\u30eb\u3092\u7f6e\u3044\u3066\u307f\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1a\u30d6\u30e9\u30a6\u30b6\u4e0a\u3067\u30d5\u30a1\u30a4\u30eb\u3092\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\uff0f\u65b0\u898f\u4f5c\u6210\uff09</p>"},{"location":"first-steps/#3-readme","title":"3. README\u3092\u66f8\u3044\u3066\u307f\u308b","text":"<p>\uff08\u3053\u3053\u306b\u624b\u9806\u3092\u66f8\u304d\u307e\u3059\uff1aREADME\u3068\u306f\u4f55\u304b\u3001\u7c21\u5358\u306a\u66f8\u304d\u65b9\uff09</p>"},{"location":"glossary/","title":"\u7528\u8a9e\u96c6\uff08\u307e\u305a\u306f\u3053\u3053\u304b\u3089\uff09","text":"<p>GitHub\u3067\u3088\u304f\u51fa\u3066\u304f\u308b\u8a00\u8449\u3092\u3001\u8eab\u8fd1\u306a\u305f\u3068\u3048\u3067\u8aac\u660e\u3057\u307e\u3059\u3002 \u5b8c\u74a7\u306b\u899a\u3048\u308b\u5fc5\u8981\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u300c\u3053\u3093\u306a\u30a4\u30e1\u30fc\u30b8\u300d\u3068\u3064\u304b\u3081\u308c\u3070\u5341\u5206\u3067\u3059\u3002</p> <p>\u8aad\u307f\u65b9</p> <p>\u4e0a\u304b\u3089\u9806\u306b\u3001\u3060\u3093\u3060\u3093\u4f7f\u3046\u8a00\u8449\u304c\u51fa\u3066\u304d\u307e\u3059\u3002\u5206\u304b\u3089\u306a\u3044\u8a00\u8449\u304c\u51fa\u3066\u304d\u305f\u3089\u3001\u3053\u306e\u30da\u30fc\u30b8\u306b\u623b\u3063\u3066\u304d\u3066\u304f\u3060\u3055\u3044\u3002</p>"},{"location":"glossary/#_2","title":"\u57fa\u672c\u306e\u8a00\u8449","text":""},{"location":"glossary/#repository-repo","title":"\u30ea\u30dd\u30b8\u30c8\u30ea\uff08Repository / \u7565\u3057\u3066 repo\uff09","text":"<p>\u30d5\u30a1\u30a4\u30eb\u3092\u5165\u308c\u3066\u304a\u304f\u300c\u30d5\u30a9\u30eb\u30c0\uff08\u4fdd\u7ba1\u7bb1\uff09\u300d\u306e\u3053\u3068\u3067\u3059\u3002 \u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3084\u8cc7\u6599\u3054\u3068\u306b1\u3064\u4f5c\u308a\u307e\u3059\u3002</p> <p>\ud83d\udcc1 \u305f\u3068\u3048\uff1a\u300c\u25cb\u25cb\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u300d\u3068\u3044\u3046\u540d\u524d\u306e\u7bb1\u30921\u3064\u7528\u610f\u3059\u308b\u30a4\u30e1\u30fc\u30b8\u3002</p> <p>\u300crepo\u300d\u3063\u3066\u7565\u3059\u306e\uff1f</p> <p>\u306f\u3044\u3002\u82f1\u8a9e\u570f\u3067\u306f\u300c\u30ea\u30dd\u30b8\u30c8\u30ea\u300d\u3092 repo\uff08\u30ec\u30dd\uff09 \u3068\u7565\u3059\u306e\u304c\u4e00\u822c\u7684\u3067\u3059\u3002 \u753b\u9762\u3084\u30c4\u30fc\u30eb\u3067\u3082 <code>repo</code> \u3068\u8868\u793a\u3055\u308c\u308b\u3053\u3068\u304c\u3042\u308b\u306e\u3067\u3001\u899a\u3048\u3066\u304a\u304f\u3068\u8ff7\u3044\u307e\u305b\u3093\u3002</p>"},{"location":"glossary/#commit","title":"\u30b3\u30df\u30c3\u30c8\uff08Commit\uff09","text":"<p>\u5909\u66f4\u3092\u8a18\u9332\u3057\u3066\u4fdd\u5b58\u3059\u308b\u3053\u3068\u3067\u3059\u3002\u300c\u3053\u3053\u307e\u3067\u306e\u4f5c\u696d\u306b\u540d\u524d\u3092\u3064\u3051\u3066\u8a18\u9332\u300d\u3068\u3044\u3046\u611f\u899a\u3002 \u30b3\u30df\u30c3\u30c8\u306b\u306f\u300c\u4f55\u3092\u5909\u3048\u305f\u304b\u300d\u306e\u3072\u3068\u3053\u3068\u30e1\u30e2\uff08\u30b3\u30df\u30c3\u30c8\u30e1\u30c3\u30bb\u30fc\u30b8\uff09\u3092\u4ed8\u3051\u307e\u3059\u3002</p> <p>\ud83d\udcbe \u305f\u3068\u3048\uff1a\u30b2\u30fc\u30e0\u306e\u300c\u30bb\u30fc\u30d6\u30dd\u30a4\u30f3\u30c8\u300d\u3002\u3042\u3068\u304b\u3089\u305d\u306e\u30dd\u30a4\u30f3\u30c8\u306b\u623b\u308c\u308b\u3002</p>"},{"location":"glossary/#push","title":"\u30d7\u30c3\u30b7\u30e5\uff08Push\uff09","text":"<p>\u81ea\u5206\u306ePC\u3067\u8a18\u9332\u3057\u305f\u5909\u66f4\u3092\u3001GitHub\uff08\u30cd\u30c3\u30c8\u4e0a\uff09\u306b\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3059\u308b\u3053\u3068\u3067\u3059\u3002</p> <p>\u2b06\ufe0f \u305f\u3068\u3048\uff1a\u624b\u5143\u3067\u66f8\u3044\u305f\u66f8\u985e\u3092\u30af\u30e9\u30a6\u30c9\u306b\u30a2\u30c3\u30d7\u3057\u3066\u3001\u307f\u3093\u306a\u304c\u898b\u3089\u308c\u308b\u72b6\u614b\u306b\u3059\u308b\u3002</p>"},{"location":"glossary/#pull","title":"\u30d7\u30eb\uff08Pull\uff09","text":"<p>GitHub\uff08\u30cd\u30c3\u30c8\u4e0a\uff09\u306b\u3042\u308b\u6700\u65b0\u306e\u72b6\u614b\u3092\u3001\u81ea\u5206\u306ePC\u306b\u53d6\u308a\u8fbc\u3080\u3053\u3068\u3067\u3059\u3002\u30d7\u30c3\u30b7\u30e5\u306e\u9006\u65b9\u5411\u3002</p> <p>\u2b07\ufe0f \u305f\u3068\u3048\uff1a\u30af\u30e9\u30a6\u30c9\u4e0a\u306e\u6700\u65b0\u7248\u3092\u624b\u5143\u306b\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3059\u308b\u3002</p>"},{"location":"glossary/#_3","title":"\u5171\u540c\u4f5c\u696d\u306e\u8a00\u8449","text":""},{"location":"glossary/#branch","title":"\u30d6\u30e9\u30f3\u30c1\uff08Branch\uff09","text":"<p>\u4f5c\u696d\u7528\u306e\u300c\u5206\u304b\u308c\u9053\u300d\u3067\u3059\u3002\u672c\u4f53\uff08\u307f\u3093\u306a\u304c\u4f7f\u3046\u7248\uff09\u306b\u5f71\u97ff\u3092\u4e0e\u3048\u305a\u306b\u3001\u5225\u306e\u5834\u6240\u3067\u5b89\u5fc3\u3057\u3066\u4f5c\u696d\u3067\u304d\u307e\u3059\u3002</p> <p>\ud83c\udf3f \u305f\u3068\u3048\uff1a\u6e05\u66f8\u7528\u306e\u30ce\u30fc\u30c8\uff08\u672c\u4f53\uff09\u3068\u306f\u5225\u306b\u3001\u4e0b\u66f8\u304d\u7528\u306e\u30ce\u30fc\u30c8\u3092\u7528\u610f\u3059\u308b\u30a4\u30e1\u30fc\u30b8\u3002</p>"},{"location":"glossary/#merge","title":"\u30de\u30fc\u30b8\uff08Merge\uff09","text":"<p>\u30d6\u30e9\u30f3\u30c1\u3067\u306e\u4f5c\u696d\u3092\u672c\u4f53\u306b\u5408\u6d41\u3055\u305b\u308b\u3053\u3068\u3067\u3059\u3002\u4e0b\u66f8\u304d\u304c\u5b8c\u6210\u3057\u305f\u3089\u3001\u6e05\u66f8\u306b\u53cd\u6620\u3059\u308b\u611f\u899a\u3002</p> <p>\ud83d\udd00 \u305f\u3068\u3048\uff1a\u4e0b\u66f8\u304d\u30ce\u30fc\u30c8\u306e\u5185\u5bb9\u3092\u3001\u6e05\u66f8\u30ce\u30fc\u30c8\u306b\u307e\u3068\u3081\u308b\u3002</p>"},{"location":"glossary/#pull-request-pr","title":"\u30d7\u30eb\u30ea\u30af\u30a8\u30b9\u30c8\uff08Pull Request / \u7565\u3057\u3066\u30d7\u30eb\u30ea\u30af\u30fbPR\uff09","text":"<p>\u300c\u3053\u306e\u5909\u66f4\u3092\u672c\u4f53\u306b\u5165\u308c\u3066\u3044\u3044\u3067\u3059\u304b\uff1f\u300d\u3068\u3044\u3046\u78ba\u8a8d\u30fb\u76f8\u8ac7\u306e\u4f9d\u983c\u3067\u3059\u3002 \u307b\u304b\u306e\u4eba\u306b\u898b\u3066\u3082\u3089\u3063\u3066\u304b\u3089\uff08\u30ec\u30d3\u30e5\u30fc\uff09\u3001\u30de\u30fc\u30b8\u3059\u308b\u306e\u304c\u4e00\u822c\u7684\u3067\u3059\u3002</p> <p>\ud83d\ude4b \u305f\u3068\u3048\uff1a\u300c\u3053\u306e\u4fee\u6b63\u3067OK\u3067\u3059\u304b\uff1f\u300d\u3068\u4e0a\u53f8\u306b\u78ba\u8a8d\u3057\u3066\u3082\u3089\u3063\u3066\u304b\u3089\u6e05\u66f8\u306b\u53cd\u6620\u3059\u308b\u3002</p>"},{"location":"glossary/#_4","title":"\u305d\u306e\u4ed6\u3088\u304f\u898b\u308b\u8a00\u8449","text":"\u30a2\u30a4\u30b3\u30f3 \u8a00\u8449 \u304b\u3093\u305f\u3093\u306a\u610f\u5473 \u30af\u30ed\u30fc\u30f3\uff08Clone\uff09 GitHub\u4e0a\u306e\u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u4e38\u3054\u3068\u81ea\u5206\u306ePC\u306b\u30b3\u30d4\u30fc\u3059\u308b\u3053\u3068 README\uff08\u30ea\u30fc\u30c9\u30df\u30fc\uff09 \u30ea\u30dd\u30b8\u30c8\u30ea\u306e\u300c\u8aac\u660e\u66f8\u30fb\u8868\u7d19\u300d\u306b\u306a\u308b\u30d5\u30a1\u30a4\u30eb Issue\uff08\u30a4\u30b7\u30e5\u30fc\uff09 \u3084\u308b\u3053\u3068\u30fb\u8ab2\u984c\u30fb\u30d0\u30b0\u306a\u3069\u3092\u8a18\u9332\u3057\u3066\u304a\u304f\u4ed8\u7b8b\u306e\u3088\u3046\u306a\u3082\u306e GitHub Pages GitHub\u306e\u30d5\u30a1\u30a4\u30eb\u3092Web\u30b5\u30a4\u30c8\u3068\u3057\u3066\u7121\u6599\u516c\u958b\u3067\u304d\u308b\u4ed5\u7d44\u307f\uff08\u3053\u306e\u8cc7\u6599\u3082\u3053\u308c\u3067\u516c\u958b\uff09 <p>Git \u3068 GitHub \u306e\u9055\u3044</p> <ul> <li> Git \u2026 \u5909\u66f4\u5c65\u6b74\u3092\u7ba1\u7406\u3059\u308b\u300c\u4ed5\u7d44\u307f\u30fb\u9053\u5177\u300d\u305d\u306e\u3082\u306e</li> <li> GitHub \u2026 \u305d\u306e\u4ed5\u7d44\u307f\u3092Web\u3067\u307f\u3093\u306a\u304c\u4f7f\u3048\u308b\u3088\u3046\u306b\u3057\u305f\u300c\u30b5\u30fc\u30d3\u30b9\u30fb\u7f6e\u304d\u5834\u6240\u300d</li> </ul> <p>\u307e\u305a\u306f\u300cGitHub\uff1d\u307f\u3093\u306a\u3067\u4f7f\u3048\u308b\u30d5\u30a1\u30a4\u30eb\u7f6e\u304d\u5834\uff0b\u5c65\u6b74\u7ba1\u7406\u300d\u3068\u899a\u3048\u3066\u304a\u3051\u3070\u5927\u4e08\u592b\u3067\u3059\u3002</p> <p>\u8a00\u8449\u306e\u30a4\u30e1\u30fc\u30b8\u304c\u3064\u304b\u3081\u305f\u3089\u3001\u6b21\u306f\u30a2\u30ab\u30a6\u30f3\u30c8\u4f5c\u6210\u3068\u521d\u671f\u8a2d\u5b9a\u306b\u9032\u307f\u307e\u3057\u3087\u3046\u3002</p>"},{"location":"troubleshooting/","title":"\u56f0\u3063\u305f\u3068\u304d\u306eQ&amp;A","text":"<p>\u3088\u304f\u3042\u308b\u3064\u307e\u305a\u304d\u3068\u3001\u305d\u306e\u5bfe\u51e6\u3092\u307e\u3068\u3081\u307e\u3059\u3002\uff08\u9806\u6b21\u8ffd\u8a18\u3057\u3066\u3044\u304d\u307e\u3059\uff09</p>"},{"location":"troubleshooting/#_1","title":"\u3088\u304f\u3042\u308b\u8cea\u554f","text":"\u9593\u9055\u3048\u3066\u30b3\u30df\u30c3\u30c8\u3057\u3066\u3057\u307e\u3063\u305f\u3002\u5143\u306b\u623b\u305b\u308b\uff1f <p>\uff08\u3053\u3053\u306b\u56de\u7b54\u3092\u66f8\u304d\u307e\u3059\uff09</p> \u300c\u6700\u65b0\u7248\u300d\u304c\u3069\u308c\u304b\u5206\u304b\u3089\u306a\u304f\u306a\u3063\u305f <p>\uff08\u3053\u3053\u306b\u56de\u7b54\u3092\u66f8\u304d\u307e\u3059\uff09</p> \u82f1\u8a9e\u3070\u304b\u308a\u3067\u4f55\u3092\u62bc\u305b\u3070\u3044\u3044\u304b\u5206\u304b\u3089\u306a\u3044 <p>\uff08\u3053\u3053\u306b\u56de\u7b54\u3092\u66f8\u304d\u307e\u3059\uff1a\u4e3b\u8981\u30dc\u30bf\u30f3\u306e\u548c\u8a33\u4e00\u89a7\uff09</p>"},{"location":"troubleshooting/#_2","title":"\u7528\u8a9e\u30fb\u30dc\u30bf\u30f3\u65e9\u898b\u8868","text":"\u82f1\u8a9e\u8868\u8a18 \u610f\u5473 Repository \u30ea\u30dd\u30b8\u30c8\u30ea\uff08\u30d5\u30a1\u30a4\u30eb\u7f6e\u304d\u5834\uff09 Commit \u5909\u66f4\u3092\u8a18\u9332\u3059\u308b Push \u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3059\u308b Pull \u53d6\u308a\u8fbc\u3080 Branch \u4f5c\u696d\u7528\u306e\u679d\u5206\u304b\u308c Merge \u672c\u4f53\u306b\u5408\u6d41\u3059\u308b Pull Request \u5909\u66f4\u306e\u78ba\u8a8d\u4f9d\u983c <p>\u305d\u308c\u3067\u3082\u89e3\u6c7a\u3057\u306a\u3044\u3068\u304d</p> <p>\u793e\u5185\u306e\u8a73\u3057\u3044\u4eba\u306b\u805e\u304f\u3001\u307e\u305f\u306f\u516c\u5f0f\u30d8\u30eb\u30d7\uff08\u65e5\u672c\u8a9e\u3042\u308a\uff09\u3092\u53c2\u7167\u3057\u307e\u3057\u3087\u3046\u3002</p>"},{"location":"images/","title":"\u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\uff08\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8\uff09\u7f6e\u304d\u5834","text":"<p>\u3053\u306e\u30d5\u30a9\u30eb\u30c0\u306b\u3001\u5404\u30da\u30fc\u30b8\u3067\u4f7f\u3046\u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\u753b\u50cf\u3092\u5165\u308c\u307e\u3059\u3002</p>"},{"location":"images/#_2","title":"\u4f7f\u3044\u65b9","text":"<ol> <li>\u753b\u9762\u3092\u64ae\u5f71\u3057\u3066\u3001\u308f\u304b\u308a\u3084\u3059\u3044\u540d\u524d\u3067\u4fdd\u5b58\u3057\u307e\u3059</li> <li>\u4f8b\uff1a<code>account-01-signup.png</code>\uff08\u7ae0\u540d-\u9023\u756a-\u5185\u5bb9\uff09</li> <li>\u672c\u6587\u306e\u300c\ud83d\udcf7 \u753b\u9762\u30ad\u30e3\u30d7\u30c1\u30e3\u67a0\u300d\u3068\u66f8\u304b\u308c\u305f\u5834\u6240\u306b\u3001\u6b21\u306e\u3088\u3046\u306b\u5dee\u3057\u8fbc\u307f\u307e\u3059</li> </ol> <pre><code>![Sign up\u30dc\u30bf\u30f3\u306e\u5834\u6240](images/account-01-signup.png){ width=\"700\" }\n</code></pre> <ul> <li><code>{ width=\"700\" }</code> \u3067\u6a2a\u5e45\u3092\u6307\u5b9a\u3067\u304d\u307e\u3059\uff08\u7701\u7565\u53ef\uff09</li> </ul> <p>\u64ae\u5f71\u306e\u30b3\u30c4</p> <ul> <li>\u62bc\u3059\u30dc\u30bf\u30f3\u306e\u5468\u308a\u3092 \u8d64\u67a0 \u3067\u56f2\u3080\u3068\u3001\u3069\u3053\u3092\u64cd\u4f5c\u3059\u308b\u304b\u4e00\u76ee\u3067\u4f1d\u308f\u308a\u307e\u3059</li> <li>\u500b\u4eba\u60c5\u5831\uff08\u5b9f\u5728\u306e\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u30fb\u6c0f\u540d\uff09\u304c\u5199\u308a\u8fbc\u307e\u306a\u3044\u3088\u3046\u6ce8\u610f\u3057\u3066\u304f\u3060\u3055\u3044</li> </ul>"},{"location":"images/illustrations/CREDITS/","title":"\u30a4\u30e9\u30b9\u30c8\u306e\u51fa\u5178\u30fb\u30e9\u30a4\u30bb\u30f3\u30b9","text":"<p>\u3053\u306e\u30d5\u30a9\u30eb\u30c0\u306e\u30a4\u30e9\u30b9\u30c8\u306f unDraw\uff08\u4f5c\u8005: Katerina Limpitsouni\uff09\u306e\u3082\u306e\u3067\u3059\u3002</p> <ul> <li>\u516c\u5f0f\u30b5\u30a4\u30c8: https://undraw.co/</li> <li>\u30e9\u30a4\u30bb\u30f3\u30b9: MIT\u30e9\u30a4\u30af\uff08\u30aa\u30fc\u30d7\u30f3\u30e9\u30a4\u30bb\u30f3\u30b9\uff09 \u2026 \u5546\u7528\u5229\u7528OK\u30fb\u5e30\u5c5e\uff08\u30af\u30ec\u30b8\u30c3\u30c8\uff09\u8868\u8a18\u306f\u4e0d\u8981</li> <li>\u53d6\u5f97\u5143\uff08SVG\u30b3\u30ec\u30af\u30b7\u30e7\u30f3\u30fbMIT\uff09: https://github.com/balazser/undraw-svg-collection</li> </ul> <p>\u8272\u306b\u3064\u3044\u3066</p> <p>\u5143\u306eSVG\u306f\u8272\u3092CSS\u5909\u6570 <code>--primary-svg-color</code> \u3067\u6307\u5b9a\u3057\u3066\u3044\u307e\u3059\u304c\u3001 \u753b\u50cf\u3068\u3057\u3066\u78ba\u5b9f\u306b\u8868\u793a\u3055\u308c\u308b\u3088\u3046\u3001\u57fa\u8abf\u8272\u3092 <code>#6c63ff</code>\uff08unDraw\u306e\u6a19\u6e96\u8272\uff09\u306b\u56fa\u5b9a\u3057\u3066\u3042\u308a\u307e\u3059\u3002 \u30c6\u30fc\u30de\u306b\u5408\u308f\u305b\u3066\u8272\u3092\u5909\u3048\u305f\u3044\u5834\u5408\u306f\u3001\u5404SVG\u5185\u306e <code>#6c63ff</code> \u3092\u4e00\u62ec\u7f6e\u63db\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p>"}]}